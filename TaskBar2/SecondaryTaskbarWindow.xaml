<Window x:Class="TaskBar2.SecondaryTaskbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TaskBar2"
        Title="TaskBar2"
        Height="{Binding TaskbarHeight}"
        Width="900"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="{StaticResource TaskbarBackgroundBrush}">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Settings" Click="SettingsMenuItem_Click" />
            <MenuItem Header="Refresh" Click="RefreshMenuItem_Click" />
            <MenuItem Header="Open log" Click="OpenLogMenuItem_Click" />
            <Separator />
            <MenuItem Header="Exit" Click="ExitMenuItem_Click" />
        </ContextMenu>
    </Window.ContextMenu>

    <Window.Resources>
        <Style x:Key="TaskbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TaskbarTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource TaskbarHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ScrollViewer x:Name="AppScrollViewer"
                      Grid.Column="0"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled">
            <Grid MinWidth="{Binding ActualWidth, ElementName=AppScrollViewer}">
                <ItemsControl ItemsSource="{Binding Items}"
                              HorizontalAlignment="{Binding TaskbarButtonPanelAlignment}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource TaskbarButtonStyle}"
                                    Width="{Binding DataContext.TaskbarButtonWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Height="{Binding DataContext.TaskbarButtonHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Margin="{Binding DataContext.TaskbarButtonMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Background="{Binding BackgroundBrush}"
                                    BorderBrush="{Binding AccentBrush}"
                                    ToolTip="{Binding Title}"
                                    Click="TaskbarButton_Click"
                                    MouseRightButtonUp="TaskbarButton_RightClick">
                                <Grid>
                                    <Border Width="{Binding ProgressFillWidth}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch"
                                            Background="{Binding ProgressBrush}"
                                            Opacity="0.36"
                                            Visibility="{Binding ProgressVisibility}" />
                                    <Image Source="{Binding Icon}"
                                           Width="{Binding DataContext.TaskbarIconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Height="{Binding DataContext.TaskbarIconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                    <Border Width="{Binding DataContext.TaskbarUnderlineWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Height="2"
                                            CornerRadius="1"
                                            VerticalAlignment="Bottom"
                                            Background="{Binding AccentBrush}"
                                            Visibility="{Binding RunningIndicatorVisibility}" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <local:TrayMirrorControl Grid.Column="1"
                                 Height="{Binding TaskbarHeight}" />
    </Grid>
</Window>

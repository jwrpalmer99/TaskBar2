<Application x:Class="TaskBar2.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="TaskbarBackgroundBrush" Color="#202020" />
        <SolidColorBrush x:Key="TaskbarHoverBrush" Color="#333333" />
        <SolidColorBrush x:Key="TaskbarActiveBrush" Color="#3A4A5F" />
        <SolidColorBrush x:Key="TaskbarTextBrush" Color="#F3F3F3" />
    </Application.Resources>
</Application>
